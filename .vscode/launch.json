    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: DataPipe",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": ["--hull", "H2521", "--start", "2026-03-01", "--end", "2026-03-02", "-c"]
            // "args": ["--hull", "H2508", "--date", "2025-06-01"]
        },
        {
            "name": "Python Debugger: Meta Upload",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": ["--path", "resources/csv/H2521_metadata.csv"]
            // "args": ["--hull", "H2508", "--date", "2025-06-01"]
        }
    ]
}