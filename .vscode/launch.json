{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: DataPipe",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": ["--hull", "H0000", "--start", "2026-03-01", "--end", "2026-03-02", "-c", "--meta", "resources/csv/H0000_metadata.csv"]
        },
        {
            "name": "Python Debugger: Meta Upload",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": ["--path", "resources/csv/H2521_metadata.csv"]
        },
        {
            "name": "Python Debugger: Append Columns",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": ["--hull", "H0000", "--start", "2026-03-01", "--end", "2026-03-02", "--meta", "resources/csv/H0000_append_columns.csv"]
        },
        {
            "type": "bashdb",
            "request": "launch",
            "name": "Bash Debug (현재 파일)",
            "cwd": "${workspaceFolder}",
            "program": "${file}",
            "terminalKind": "integrated"
        }
    ]
}